{
  "name": "portfolio",
  "private": true,
  "version": "0.3.1",
  "type": "module",
  "homepage": "https://www.theodorosmentis.com",
  "description": "Modern portfolio website built with React, Vite, and Tailwind CSS",
  "keywords": [
    "portfolio",
    "react",
    "vite",
    "tailwindcss",
    "typescript"
  ],
  "author": "Theodoros Mentis",
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build && npm run prerender && npm run validate:seo",
    "prerender": "node scripts/prerender.mjs",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "pretest:smoke": "playwright install --with-deps chromium || playwright install chromium",
    "test:smoke": "playwright test",
    "test:ci": "npm run test && npm run test:smoke",
    "clean": "npx rimraf dist node_modules/.vite",
    "check-urls": "node scripts/check-project-urls.js",
    "verify:sw-precache": "node scripts/verify-sw-precache.js",
    "validate:project-data": "node scripts/validate-project-data.js",
    "validate:seo": "node scripts/validate-seo.mjs",
    "performance:analyze": "npm run build && npx vite-bundle-visualizer -o bundle-report.html",
    "deploy:redirect": "echo 'Redirect deployment is handled by .github/workflows/redirect-deploy.yml. Commit deploy/redirect.html changes and push to main, or run: gh workflow run redirect-deploy.yml'",
    "deploy:redirect:trigger": "gh workflow run redirect-deploy.yml"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/space-grotesk": "^5.2.10",
    "@tailwindcss/container-queries": "^0.1.1",
    "@vercel/analytics": "^1.5.0",
    "@vercel/speed-insights": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.15.0",
    "lucide-react": "^0.511.0",
    "posthog-js": "^1.256.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^7.18.0",
    "react-typed": "^2.0.12",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.21",
    "eslint": "^8.57.1",
    "eslint-plugin-react": "^7.34.4",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "jsdom": "^29.0.2",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.35.1",
    "vite": "^7.3.0",
    "vite-bundle-visualizer": "^1.2.1",
    "vitest": "^4.1.5"
  }
}
